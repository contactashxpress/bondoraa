#: accounts/emails.py:11
msgid "Vérifiez votre adresse e-mail - Bondoraa"
msgstr "Überprüfen Sie Ihre E-Mail-Adresse - Bondoraa"

#: accounts/emails.py:13
#, python-format
msgid ""
"Bonjour,\n"
"\n"
"Merci de vous être inscrit sur Bondoraa. Pour activer votre compte, cliquez "
"sur le lien ci-dessous :\n"
"\n"
"%(verify_url)s\n"
"\n"
"Ce lien expire dans 24 heures.\n"
"\n"
"Si vous n'avez pas créé de compte, vous pouvez ignorer cet e-mail.\n"
"\n"
"L'équipe Bondoraa"
msgstr ""
"Hallo,\n"
"\n"
"Vielen Dank für Ihre Anmeldung bei Bondoraa. Um Ihr Konto zu aktivieren, klicken Sie auf den folgenden Link:\n"
"\n"
"%(verify_url)s\n"
"\n"
"Dieser Link läuft in 24 Stunden ab.\n"
"\n"
"Wenn Sie kein Konto erstellt haben, können Sie diese E-Mail ignorieren.\n"
"\n"
"Das Bondoraa-Team"

