#: accounts/emails.py:12
msgid "Vérifiez votre adresse e-mail - Bondoraa"
msgstr "Verify your email address - Bondoraa"

#: accounts/emails.py:16
#, python-format
msgid ""
"Bonjour,\n"
"\n"
"Merci de vous être inscrit sur Bondoraa. Pour activer votre compte, cliquez "
"sur le lien ci-dessous :\n"
"\n"
"%(verify_url)s\n"
"\n"
"Ce lien expire dans 24 heures.\n"
"\n"
"Si vous n'avez pas créé de compte, vous pouvez ignorer cet e-mail.\n"
"\n"
"L'équipe Bondoraa"
msgstr ""
"Hello,\n"
"\n"
"Thank you for signing up on Bondoraa. To activate your account, click the "
"link below:\n"
"\n"
"%(verify_url)s\n"
"\n"
"This link expires in 24 hours.\n"
"\n"
"If you did not create an account, you can ignore this email.\n"
"\n"
"The Bondoraa team"

