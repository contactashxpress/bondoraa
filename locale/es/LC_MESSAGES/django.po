#: accounts/emails.py:12
msgid "Vérifiez votre adresse e-mail - Bondoraa"
msgstr "Verifique su dirección de correo electrónico - Bondoraa"

#: accounts/emails.py:16
#, python-format
msgid ""
"Bonjour,\n"
"\n"
"Merci de vous être inscrit sur Bondoraa. Pour activer votre compte, cliquez "
"sur le lien ci-dessous :\n"
"\n"
"%(verify_url)s\n"
"\n"
"Ce lien expire dans 24 heures.\n"
"\n"
"Si vous n'avez pas créé de compte, vous pouvez ignorer cet e-mail.\n"
"\n"
"L'équipe Bondoraa"
msgstr ""
"Hola,\n"
"\n"
"Gracias por registrarse en Bondoraa. Para activar su cuenta, haga clic en el "
"enlace a continuación:\n"
"\n"
"%(verify_url)s\n"
"\n"
"Este enlace caduca en 24 horas.\n"
"\n"
"Si no ha creado una cuenta, puede ignorar este correo electrónico.\n"
"\n"
"El equipo de Bondoraa"

